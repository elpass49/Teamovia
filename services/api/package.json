{
  "name": "@teamovia/api",
  "version": "1.0.0",
  "private": true,
  "description": "Teamovia backend API — support/sales agents, orchestration, webhooks",
  "type": "module",
  "scripts": {
    "dev": "node --import tsx --watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "@hono/node-server": "^1.0.0",
    "@hono/zod-validator": "^0.2.0",
    "zod": "^3.22.0",
    "@supabase/supabase-js": "^2.43.0",
    "ai": "^3.0.0",
    "@ai-sdk/anthropic": "^0.0.40",
    "@teamovia/agents-sdk": "workspace:*",
    "@teamovia/prompts": "workspace:*",
    "@teamovia/types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "@types/node": "^20.0.0",
    "vitest": "^1.0.0",
    "eslint": "^8.54.0"
  }
}
