{
  "name": "@teamovia/types",
  "version": "1.0.0",
  "private": true,
  "description": "Teamovia shared types — database, API, models",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./database": {
      "types": "./dist/database.d.ts",
      "default": "./dist/database.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src --max-warnings 0",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "eslint": "^8.54.0"
  }
}
